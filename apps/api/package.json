{
  "name": "@teamflow/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "@hono/node-server": "^1.18.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.6.1",
    "hono": "^4.9.0",
    "mongoose": "^8.12.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^24.12.0",
    "prettier": "^3.8.3",
    "tsx": "^4.20.5",
    "typescript": "~5.9.3"
  }
}
