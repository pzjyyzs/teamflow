    "format:check": "prettier --check \"src/**/*.{ts,vue,json}\""
  },
  "dependencies": {
    "axios": "^1.13.6",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "vite": "^8.0.1",
    "vue-tsc": "^3.2.5"
  }
}